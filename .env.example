# Copy to .env and fill in. Never commit .env.

# === Database Configuration ===
# [Local] Local Postgres container
DATABASE_URL=postgres://tariffshield:tariffshield_dev_password@localhost:5443/tariffshield
# [Staging] Neon free tier or Render Managed Postgres (STAGING_DATABASE_URL in GitHub Secrets)
# [Production] Production-grade PostgreSQL database (DATABASE_URL in Render)

# === API Configuration ===
PORT=3002
# [Local] development | [Staging/Production] production
NODE_ENV=development
# [Local] http://localhost:3000
# [Staging] Staging Vercel URL (e.g., https://tariffshield-web-staging.vercel.app)
# [Production] Production Web URL (e.g., https://tariffshield.com)
FRONTEND_ORIGIN=http://localhost:3000

# === Authentication ===
# [Local/Staging/Production] Must be a secure 64-character hex string unique to each tier
JWT_SECRET=replace-with-64-hex-chars

# === Stellar Network Configuration ===
# [Local/Staging] testnet | [Production] public
STELLAR_NETWORK=testnet
# [Local/Staging] https://soroban-testnet.stellar.org
# [Production] Mainnet Soroban RPC endpoint (e.g., https://soroban-rpc.stellar.org or custom provider)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# [Local/Staging] https://horizon-testnet.stellar.org
# [Production] Mainnet Horizon endpoint (e.g., https://horizon.stellar.org)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# [Local/Staging] Test SDF Network ; September 2015
# [Production] Public Global Stellar Network ; October 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# === Keypairs ===
# Platform keypair (funded via friendbot on Testnet — see scripts/seed.ts)
# [Staging] Dedicated staging admin keypair (STAGING_STELLAR_SECRET_KEY in GitHub Secrets)
# [Production] Mainnet platform admin keypair (funded with real XLM/USDC)
PLATFORM_STELLAR_SECRET=
PLATFORM_STELLAR_PUBLIC=

# Mock surety keypair (admin/clawback authority of the contract)
# [Local/Staging] Testnet account
# [Production] Mainnet surety keypair
SURETY_STELLAR_SECRET=
SURETY_STELLAR_PUBLIC=

# USDC asset (testnet USDC issued by platform for the demo)
# [Local/Staging] Testnet USDC issuer
# [Production] Mainnet Circle USDC contract address
USDC_ISSUER_SECRET=
USDC_ISSUER_PUBLIC=

# === Smart Contracts ===
# Deployed contract ID — populated by scripts/deploy-contracts.ts
# [Staging] Staging contract ID (STAGING_CONTRACT_ID in GitHub Secrets)
# [Production] Mainnet contract ID
TARIFF_SHIELD_CONTRACT_ID=

# === Render Deployment ===
# [Staging] Staging Render deploy hook (STAGING_RENDER_DEPLOY_HOOK_URL in GitHub Secrets)
# [Production] Production Render deploy hook (RENDER_DEPLOY_HOOK_URL in GitHub Secrets)
RENDER_DEPLOY_HOOK_URL=
RENDER_SERVICE_ID=

